{
  "name": "meme-match-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Telegram-бот для подбора мемов под описанную ситуацию",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
"parse-templates": "tsx scripts/parse-imgflip.ts",
    "enrich-templates": "tsx scripts/enrich-memes.ts",
    "embed-templates": "tsx scripts/generate-embeddings.ts",
    "parse-gifs": "tsx scripts/parse-imgflip.ts --type gif",
    "enrich-gifs": "tsx scripts/enrich-memes.ts --type gif",
    "embed-gifs": "tsx scripts/generate-embeddings.ts --type gif",
    "lint": "eslint .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migrate": "tsx scripts/migrate.ts"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "node-html-parser": "^7.1.0",
    "openai": "^6.25.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
